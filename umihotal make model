        "import random\n",
        "\n",
        "from PIL import Image, ImageDraw\n",
        "from IPython.display import display\n",
        "\n",
        "\n",
        "def display_yolo_sample(split_name: str = \"train\") -> None:\n",
        "    image_directory = (\n",
        "        DATASET_DIR / \"images\" / split_name\n",
        "    )\n",
        "\n",
        "    image_paths = [\n",
        "        path\n",
        "        for path in image_directory.iterdir()\n",
        "        if path.suffix.lower() in IMAGE_EXTENSIONS\n",
        "    ]\n",
        "\n",
        "    if not image_paths:\n",
        "        raise RuntimeError(\n",
        "            f\"{split_name}に画像がありません\"\n",
        "        )\n",
        "\n",
        "    image_path = random.choice(image_paths)\n",
        "\n",
        "    label_path = (\n",
        "        DATASET_DIR\n",
        "        / \"labels\"\n",
        "        / split_name\n",
        "        / f\"{image_path.stem}.txt\"\n",
        "    )\n",
        "\n",
        "    image = Image.open(image_path).convert(\"RGB\")\n",
        "    draw = ImageDraw.Draw(image)\n",
        "\n",
        "    width, height = image.size\n",
        "\n",
        "    if label_path.is_file():\n",
        "        for line in label_path.read_text().splitlines():\n",
        "            if not line.strip():\n",
        "                continue\n",
        "\n",
        "            class_id, cx, cy, box_w, box_h = map(\n",
        "                float,\n",
        "                line.split(),\n",
        "            )\n",
        "\n",
        "            cx *= width\n",
        "            cy *= height\n",
        "            box_w *= width\n",
        "            box_h *= height\n",
        "\n",
        "            x1 = cx - box_w / 2\n",
        "            y1 = cy - box_h / 2\n",
        "            x2 = cx + box_w / 2\n",
        "            y2 = cy + box_h / 2\n",
        "\n",
        "            draw.rectangle(\n",
        "                [x1, y1, x2, y2],\n",
        "                outline=\"red\",\n",
        "                width=3,\n",
        "            )\n",
        "\n",
        "    print(image_path.name)\n",
        "    display(image)\n",
        "\n",
        "\n",
        "display_yolo_sample(\"train\")"
      ],
