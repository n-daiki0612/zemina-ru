      "cell_type": "code",
      "source": [
        "from __future__ import annotations\n",
        "\n",
        "import json\n",
        "import random\n",
        "import shutil\n",
        "from pathlib import Path\n",
        "\n",
        "import yaml\n",
        "from PIL import Image\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# 設定\n",
        "# -----------------------------\n",
        "\n",
        "DATASET_DIR = Path(\"/content/umihotaru_yolo\")\n",
        "\n",
        "SEED = 42\n",
        "\n",
        "TRAIN_RATIO = 0.70\n",
        "VAL_RATIO = 0.15\n",
        "TEST_RATIO = 0.15\n",
        "\n",
        "# X-AnyLabelingで使ったラベル名 → YOLOクラス番号\n",
        "LABEL_TO_ID = {\n",
        "    \"hotal\": 0,\n",
        "    \"umihotaru\": 0,\n",
        "    \"ウミホタル\": 0,\n",
        "}\n",
        "\n",
        "CLASS_NAMES = {\n",
        "    0: \"umihotaru\",\n",
        "}\n",
        "\n",
        "# ラベルが空の画像も背景画像として含めたい場合はTrue\n",
        "# 今回は「ラベル付きフレームのみ」なのでFalse\n",
        "INCLUDE_EMPTY_IMAGES = False\n",
        "\n",
        "IMAGE_EXTENSIONS = {\n",
        "    \".jpg\",\n",
        "    \".jpeg\",\n",
        "    \".png\",\n",
        "    \".bmp\",\n",
        "    \".webp\",\n",
        "}\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# 初期化\n",
        "# -----------------------------\n",
        "\n",
        "if abs(TRAIN_RATIO + VAL_RATIO + TEST_RATIO - 1.0) > 1e-8:\n",
        "    raise ValueError(\"分割比率の合計を1.0にしてください\")\n",
        "\n",
        "if DATASET_DIR.exists():\n",
        "    shutil.rmtree(DATASET_DIR)\n",
        "\n",
        "for split_name in (\"train\", \"val\", \"test\"):\n",
        "    (DATASET_DIR / \"images\" / split_name).mkdir(\n",
        "        parents=True,\n",
        "        exist_ok=True,\n",
        "    )\n",
        "    (DATASET_DIR / \"labels\" / split_name).mkdir(\n",
        "        parents=True,\n",
        "        exist_ok=True,\n",
        "    )\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# 対応画像の検索\n",
        "# -----------------------------\n",
        "\n",
        "images_by_stem: dict[str, list[Path]] = {}\n",
        "\n",
        "for image_path in IMAGE_DIR.rglob(\"*\"):\n",
        "    if (\n",
        "        image_path.is_file()\n",
        "        and image_path.suffix.lower() in IMAGE_EXTENSIONS\n",
        "    ):\n",
        "        images_by_stem.setdefault(image_path.stem, []).append(image_path)\n",
        "\n",
        "\n",
        "def find_image_for_json(json_path: Path) -> Path | None:\n",
        "    \"\"\"JSONと同じ相対パス・ファイル名の画像を探す。\"\"\"\n",
        "\n",
        "    relative_json = json_path.relative_to(JSON_DIR)\n",
        "\n",
        "    # 同じサブフォルダ構成を最優先\n",
        "    for extension in IMAGE_EXTENSIONS:\n",
        "        candidate = (\n",
        "            IMAGE_DIR / relative_json.with_suffix(extension)\n",
        "        )\n",
        "\n",
        "        if candidate.is_file():\n",
        "            return candidate\n",
        "\n",
        "        uppercase_candidate = candidate.with_suffix(\n",
        "            extension.upper()\n",
        "        )\n",
        "\n",
        "        if uppercase_candidate.is_file():\n",
        "            return uppercase_candidate\n",
        "\n",
        "    # 見つからない場合はstemだけで検索\n",
        "    candidates = images_by_stem.get(json_path.stem, [])\n",
        "\n",
        "    if len(candidates) == 1:\n",
        "        return candidates[0]\n",
        "\n",
        "    if len(candidates) > 1:\n",
        "        print(\n",
        "            f\"[画像候補が複数] {json_path.name}: \"\n",
        "            f\"{len(candidates)}件\"\n",
        "        )\n",
        "\n",
        "    return None\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# JSON → YOLO変換\n",
        "# -----------------------------\n",
        "\n",
        "unknown_labels: set[str] = set()\n",
        "\n",
        "\n",
        "def convert_json_to_yolo(\n",
        "    json_path: Path,\n",
        "    image_path: Path,\n",
        ") -> list[str]:\n",
        "    with json_path.open(\"r\", encoding=\"utf-8-sig\") as file:\n",
        "        data = json.load(file)\n",
        "\n",
        "    image_width = data.get(\"imageWidth\")\n",
        "    image_height = data.get(\"imageHeight\")\n",
        "\n",
        "    # JSONに画像サイズがない場合、画像から取得\n",
        "    if not image_width or not image_height:\n",
        "        with Image.open(image_path) as image:\n",
        "            image_width, image_height = image.size\n",
        "\n",
        "    image_width = float(image_width)\n",
        "    image_height = float(image_height)\n",
        "\n",
        "    if image_width <= 0 or image_height <= 0:\n",
        "        raise ValueError(\n",
        "            f\"画像サイズが不正です: {image_path}\"\n",
        "        )\n",
        "\n",
        "    yolo_lines: list[str] = []\n",
        "\n",
        "    for shape in data.get(\"shapes\", []):\n",
        "        if not isinstance(shape, dict):\n",
        "            continue\n",
        "\n",
        "        label = str(shape.get(\"label\", \"\")).strip()\n",
        "\n",
        "        # SAM2の操作用一時ラベルは除外\n",
        "        if label.startswith(\"AUTOLABEL_\"):\n",
        "            continue\n",
        "\n",
        "        normalized_label = label.lower()\n",
        "\n",
        "        if normalized_label not in LABEL_TO_ID:\n",
        "            if label:\n",
        "                unknown_labels.add(label)\n",
        "            continue\n",
        "\n",
        "        points = shape.get(\"points\", [])\n",
        "\n",
        "        if not isinstance(points, list) or len(points) < 2:\n",
        "            continue\n",
        "\n",
        "        try:\n",
        "            xs = [float(point[0]) for point in points]\n",
        "            ys = [float(point[1]) for point in points]\n",
        "        except (TypeError, ValueError, IndexError):\n",
        "            continue\n",
        "\n",
        "        # rectangleでもpolygonでも、\n",
        "        # 外接する軸平行バウンディングボックスへ変換\n",
        "        x_min = max(0.0, min(xs))\n",
        "        y_min = max(0.0, min(ys))\n",
        "        x_max = min(image_width, max(xs))\n",
        "        y_max = min(image_height, max(ys))\n",
        "\n",
        "        box_width = x_max - x_min\n",
        "        box_height = y_max - y_min\n",
        "\n",
        "        if box_width <= 0 or box_height <= 0:\n",
        "            continue\n",
        "\n",
        "        x_center = (x_min + x_max) / 2.0 / image_width\n",
        "        y_center = (y_min + y_max) / 2.0 / image_height\n",
        "        normalized_width = box_width / image_width\n",
        "        normalized_height = box_height / image_height\n",
        "\n",
        "        class_id = LABEL_TO_ID[normalized_label]\n",
        "\n",
        "        yolo_lines.append(\n",
        "            f\"{class_id} \"\n",
        "            f\"{x_center:.6f} \"\n",
        "            f\"{y_center:.6f} \"\n",
        "            f\"{normalized_width:.6f} \"\n",
        "            f\"{normalized_height:.6f}\"\n",
        "        )\n",
        "\n",
        "    return yolo_lines\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# 有効な画像とJSONを収集\n",
        "# -----------------------------\n",
        "\n",
        "records = []\n",
        "missing_image_count = 0\n",
        "invalid_json_count = 0\n",
        "\n",
        "for json_path in sorted(JSON_DIR.rglob(\"*.json\")):\n",
        "    image_path = find_image_for_json(json_path)\n",
        "\n",
        "    if image_path is None:\n",
        "        missing_image_count += 1\n",
        "        continue\n",
        "\n",
        "    try:\n",
        "        yolo_lines = convert_json_to_yolo(\n",
        "            json_path,\n",
        "            image_path,\n",
        "        )\n",
        "    except (OSError, json.JSONDecodeError, ValueError) as error:\n",
        "        print(f\"[変換失敗] {json_path.name}: {error}\")\n",
        "        invalid_json_count += 1\n",
        "        continue\n",
        "\n",
        "    if yolo_lines or INCLUDE_EMPTY_IMAGES:\n",
        "        records.append(\n",
        "            {\n",
        "                \"image\": image_path,\n",
        "                \"json\": json_path,\n",
        "                \"lines\": yolo_lines,\n",
        "            }\n",
        "        )\n",
        "\n",
        "\n",
        "if len(records) < 10:\n",
        "    raise RuntimeError(\n",
        "        f\"使用可能な画像が少なすぎます: {len(records)}枚\"\n",
        "    )\n",
        "\n",
        "print(\"使用可能な画像数:\", len(records))\n",
        "print(\"対応画像なし:\", missing_image_count)\n",
        "print(\"変換失敗:\", invalid_json_count)\n",
        "\n",
        "if unknown_labels:\n",
        "    print(\"無視された未知のラベル:\", sorted(unknown_labels))\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# ランダム分割\n",
        "# -----------------------------\n",
        "\n",
        "random_generator = random.Random(SEED)\n",
        "random_generator.shuffle(records)\n",
        "\n",
        "total_count = len(records)\n",
        "\n",
        "train_count = int(total_count * TRAIN_RATIO)\n",
        "val_count = int(total_count * VAL_RATIO)\n",
        "\n",
        "split_records = {\n",
        "    \"train\": records[:train_count],\n",
        "    \"val\": records[train_count:train_count + val_count],\n",
        "    \"test\": records[train_count + val_count:],\n",
        "}\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# ファイルをコピー\n",
        "# -----------------------------\n",
        "\n",
        "split_box_counts = {}\n",
        "\n",
        "for split_name, split_items in split_records.items():\n",
        "    box_count = 0\n",
        "\n",
        "    for item in split_items:\n",
        "        image_path = item[\"image\"]\n",
        "        yolo_lines = item[\"lines\"]\n",
        "\n",
        "        relative_image = image_path.relative_to(IMAGE_DIR)\n",
        "\n",
        "        # サブフォルダがあっても名前が衝突しないようにする\n",
        "        safe_stem = \"__\".join(\n",
        "            relative_image.with_suffix(\"\").parts\n",
        "        )\n",
        "\n",
        "        output_image_name = (\n",
        "            safe_stem + image_path.suffix.lower()\n",
        "        )\n",
        "        output_label_name = safe_stem + \".txt\"\n",
        "\n",
        "        output_image_path = (\n",
        "            DATASET_DIR\n",
        "            / \"images\"\n",
        "            / split_name\n",
        "            / output_image_name\n",
        "        )\n",
        "\n",
        "        output_label_path = (\n",
        "            DATASET_DIR\n",
        "            / \"labels\"\n",
        "            / split_name\n",
        "            / output_label_name\n",
        "        )\n",
        "\n",
        "        shutil.copy2(image_path, output_image_path)\n",
        "\n",
        "        label_text = \"\\n\".join(yolo_lines)\n",
        "\n",
        "        if label_text:\n",
        "            label_text += \"\\n\"\n",
        "\n",
        "        output_label_path.write_text(\n",
        "            label_text,\n",
        "            encoding=\"utf-8\",\n",
        "        )\n",
        "\n",
        "        box_count += len(yolo_lines)\n",
        "\n",
        "    split_box_counts[split_name] = box_count\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# data.yamlを作成\n",
        "# -----------------------------\n",
        "\n",
        "data_yaml = {\n",
        "    \"path\": str(DATASET_DIR),\n",
        "    \"train\": \"images/train\",\n",
        "    \"val\": \"images/val\",\n",
        "    \"test\": \"images/test\",\n",
        "    \"names\": CLASS_NAMES,\n",
        "}\n",
        "\n",
        "yaml_path = DATASET_DIR / \"data.yaml\"\n",
        "\n",
        "with yaml_path.open(\"w\", encoding=\"utf-8\") as file:\n",
        "    yaml.safe_dump(\n",
        "        data_yaml,\n",
        "        file,\n",
        "        allow_unicode=True,\n",
        "        sort_keys=False,\n",
        "    )\n",
        "\n",
        "\n",
        "print()\n",
        "print(\"データセット作成完了\")\n",
        "print(\"保存先:\", DATASET_DIR)\n",
        "\n",
        "for split_name in (\"train\", \"val\", \"test\"):\n",
        "    print(\n",
        "        f\"{split_name}: \"\n",
        "        f\"{len(split_records[split_name])}枚 / \"\n",
        "        f\"{split_box_counts[split_name]}個体\"\n",
        "    )\n",
        "\n",
        "print()\n",
        "print(yaml_path.read_text(encoding=\"utf-8\"))"
      ],
      "metadata": {
        "colab": {
